# Copy to .env and fill in before starting Claude Code in this project.
# These values are referenced by .mcp.json via ${VAR} expansion.

# Path to a Google Cloud service account (or ADC) credentials JSON file.
# Needs the following OAuth scopes:
#   - https://www.googleapis.com/auth/adwords            (Google Ads)
#   - https://www.googleapis.com/auth/analytics.readonly (Google Analytics)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/credentials.json

# Google Cloud project ID associated with the credentials above.
GOOGLE_PROJECT_ID=your-gcp-project-id

# Google Ads developer token (Basic/Standard/Explorer access).
# https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Optional: required only if the account you query is under a Google Ads
# manager (MCC) account.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
